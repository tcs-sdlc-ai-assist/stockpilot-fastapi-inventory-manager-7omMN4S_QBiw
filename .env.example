# StockPilot Environment Configuration
# Copy this file to .env and update values for your environment.

# SECRET_KEY: Used for session signing, CSRF tokens, and password reset tokens.
# In production, generate a strong random key (e.g., `python -c "import secrets; print(secrets.token_urlsafe(64))"`)
# NEVER use the default value in production.
SECRET_KEY=change-me-to-a-random-secret-key

# DEFAULT_ADMIN_USERNAME: Username for the initial admin account created on first run.
# Recommendation: Change this to a unique admin username in production.
DEFAULT_ADMIN_USERNAME=admin

# DEFAULT_ADMIN_PASSWORD: Password for the initial admin account created on first run.
# IMPORTANT: Change this immediately after first login in production.
# Use a strong password with at least 12 characters, mixed case, numbers, and symbols.
DEFAULT_ADMIN_PASSWORD=changeme123

# DEFAULT_ADMIN_DISPLAY_NAME: Display name shown in the UI for the initial admin account.
DEFAULT_ADMIN_DISPLAY_NAME=Administrator

# DATABASE_URL: SQLAlchemy async database connection string.
# Default uses SQLite with aiosqlite driver (suitable for development and small deployments).
# For production, consider PostgreSQL:
#   DATABASE_URL=postgresql+asyncpg://user:password@host:5432/stockpilot
# Ensure the corresponding async driver package is installed (aiosqlite, asyncpg, etc.).
DATABASE_URL=sqlite+aiosqlite:///./stockpilot.db